<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="VboxIz" prefHeight="601.0" prefWidth="343.0" spacing="15.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.RegistroPaquetes">
   <children>
      <HBox fx:id="Hbox" alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Label fx:id="lbTitulo" alignment="CENTER" prefHeight="17.0" prefWidth="253.0" text="Registro de paquetes">
               <font>
                  <Font size="22.0" />
               </font>
            </Label>
         </children>
      </HBox>
      <Label fx:id="lbCodPaq" prefHeight="17.0" prefWidth="227.0" text="Codigo del paquete">
         <VBox.margin>
            <Insets left="20.0" right="20.0" top="10.0" />
         </VBox.margin>
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
      </Label>
      <TextField fx:id="txtFieldCodPaq">
         <VBox.margin>
            <Insets left="20.0" right="20.0" />
         </VBox.margin>
      </TextField>
      <Label fx:id="lbNomDest" prefHeight="17.0" prefWidth="254.0" text="Nombre del destinatario">
         <VBox.margin>
            <Insets left="20.0" right="20.0" />
         </VBox.margin></Label>
      <TextField fx:id="txtFNomDest">
         <VBox.margin>
            <Insets left="20.0" right="20.0" />
         </VBox.margin></TextField>
      <Label fx:id="lbPesoPaq" prefHeight="17.0" prefWidth="343.0" text="Peso del paquete">
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
         <VBox.margin>
            <Insets left="20.0" right="20.0" />
         </VBox.margin>
      </Label>
      <TextField fx:id="txtFPesoPaq">
         <VBox.margin>
            <Insets left="20.0" right="20.0" />
         </VBox.margin></TextField>
      <ComboBox fx:id="CBDestinos" prefWidth="150.0" promptText="Seleccione">
         <VBox.margin>
            <Insets left="20.0" right="20.0" top="10.0" />
         </VBox.margin>
      </ComboBox>
      <HBox fx:id="Hbox" prefHeight="29.0" prefWidth="300.0" spacing="70.0">
         <children>
            <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#Guardar" prefHeight="25.0" prefWidth="100.0" text="Guardar" />
            <Button fx:id="btnCargar" mnemonicParsing="false" onAction="#Cargar" prefHeight="25.0" prefWidth="103.0" text="Cargar" />
         </children>
         <VBox.margin>
            <Insets left="35.0" right="20.0" top="40.0" />
         </VBox.margin>
      </HBox>
      <ProgressBar fx:id="PBar" prefWidth="224.0" progress="0.0">
         <VBox.margin>
            <Insets left="62.0" right="20.0" top="16.0" />
         </VBox.margin></ProgressBar>
      <Label fx:id="lbMensajeUsur" alignment="CENTER" prefHeight="22.0" prefWidth="200.0" text="Esperando...." textAlignment="CENTER">
         <VBox.margin>
            <Insets left="75.0" right="20.0" top="10.0" />
         </VBox.margin>
      </Label>
   </children>
</VBox>
